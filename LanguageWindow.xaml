<Window x:Class="DapIntuneSupportSuite.LanguageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Language"
        Height="250"
        Width="660"
        MinHeight="250"
        MinWidth="660"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="8" Padding="16">
            <StackPanel>
                <TextBlock Text="Sprache" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                <TextBlock Text="Verfügbare Sprache" FontWeight="SemiBold" Margin="0,0,0,4" />
                <ComboBox x:Name="LanguageComboBox"
                          Height="34"
                          MinWidth="520"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="LanguageId" />
                <TextBlock x:Name="InfoTextBlock"
                           Margin="0,12,0,0"
                           TextWrapping="Wrap"
                           Text="Die verfügbaren Einträge werden dynamisch aus dem Ordner Language gelesen." />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Speichern"
                    Height="34"
                    MinWidth="120"
                    Padding="12,0"
                    IsDefault="True"
                    Click="Save_Click" />
            <Button Grid.Column="2"
                    Content="Abbrechen"
                    Height="34"
                    MinWidth="120"
                    Padding="12,0"
                    IsCancel="True"
                    Click="Cancel_Click" />
        </Grid>
    </Grid>
</Window>
