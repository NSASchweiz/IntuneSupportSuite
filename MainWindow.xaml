<Window x:Class="DapIntuneSupportSuite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DapIntuneSupportSuite.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:MainViewModel}"
        Height="820"
        Width="1380"
        MinHeight="720"
        MinWidth="1120"
        Background="{StaticResource WindowBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="LocalLogTabItemStyle" TargetType="TabItem">
            <Setter Property="Background" Value="#9A9A9A" />
            <Setter Property="Foreground" Value="Black" />
        </Style>

        <Style x:Key="AppLogDataGridStyle" TargetType="DataGrid">
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="EnableRowVirtualization" Value="True" />
            <Setter Property="EnableColumnVirtualization" Value="True" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Visible" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="{Binding SeverityBrush}" />
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DashboardCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D7E0E8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="OverviewBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D7E0E8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0"
              Background="White"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Top"
              Margin="0"
              Padding="0"
              HorizontalContentAlignment="Left">
            <MenuItem Header="_Datei" HorizontalAlignment="Left">
                <MenuItem Header="_Optionen" Click="Options_Click" />
                <MenuItem Header="_Trusted Config" Click="TrustedConfig_Click" />
                <Separator />
                <MenuItem Header="_Language" Click="Language_Click" />
                <Separator />
                <MenuItem Header="_Beenden" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="_Aktionen" HorizontalAlignment="Left">
                <MenuItem Header="Log Export" Command="{Binding ExportLogBundleCommand}" />
                <Separator />
                <MenuItem Header="IME Log Reset" Command="{Binding ResetImeLogsCommand}" />
                <MenuItem Header="IME Restart" Command="{Binding RestartImeServiceCommand}" />
                <MenuItem Header="Reset App Install" Command="{Binding ResetAppInstallCommand}" />
                <Separator />
                <MenuItem Header="WSReset" Command="{Binding WsResetCommand}" />
            </MenuItem>
        </Menu>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="12" Margin="16,0,16,10">
            <Grid VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="32" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Gerätename"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4" />
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="Intune App GUID (optional)"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4" />

                <TextBox Grid.Row="1"
                         Grid.Column="0"
                         Height="32"
                         Margin="0,0,10,0"
                         Text="{Binding DeviceName, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         VerticalContentAlignment="Center" />

                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Height="32"
                         Margin="0,0,10,0"
                         Text="{Binding AppGuid, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         VerticalContentAlignment="Center" />

                <Button Grid.Row="1"
                        Grid.Column="2"
                        Height="32"
                        MinWidth="150"
                        Padding="12,0"
                        Content="Auswertung starten"
                        Command="{Binding AnalyzeCommand}"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center" />

                <Button Grid.Row="1"
                        Grid.Column="3"
                        Height="32"
                        MinWidth="100"
                        Padding="12,0"
                        Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        Margin="0"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>

        <TabControl Grid.Row="2" Margin="16,0,16,0">
            <TabItem Header="IME Health Dashboard">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource DashboardCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Auffälligkeiten" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                                    <DataGrid ItemsSource="{Binding ImeHealthIssueInsights}" Style="{StaticResource AppLogDataGridStyle}" Height="135" CanUserAddRows="False" CanUserDeleteRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Kategorie" Binding="{Binding Category}" Width="160" />
                                            <DataGridTextColumn Header="Zusammenfassung" Binding="{Binding Summary}" Width="*" MinWidth="520" />
                                            <DataGridTextColumn Header="Quelle" Binding="{Binding SourceLog}" Width="160" />
                                            <DataGridTextColumn Header="Letzter Hinweis" Binding="{Binding LastSeen}" Width="135" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource DashboardCardStyle}" Margin="0" MinHeight="135">
                                <StackPanel>
                                    <TextBlock Text="Log Signale / Auffälligkeiten" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                                    <TextBlock Text="{Binding ImeHealthRemoteLogStats}" TextWrapping="Wrap" Margin="0,0,0,6" />
                                    <TextBlock Text="{Binding ImeHealthIssueSummary}" TextWrapping="Wrap" Margin="0,0,0,6" />
                                    <TextBlock Text="{Binding ImeHealthLatestSignal}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource OverviewBorderStyle}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Erste Geräteanalyse" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Pending Restart" FontWeight="SemiBold" Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding ImeHealthPendingRestartText}" TextWrapping="Wrap" Margin="0,0,0,10" />
                                            <TextBlock Text="Enrollment / MDM" FontWeight="SemiBold" Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding ImeHealthEnrollmentSummary}" TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="App Installationen" FontWeight="SemiBold" Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding ImeHealthManagedAppsSummary}" TextWrapping="Wrap" Margin="0,0,0,10" />
                                            <TextBlock Text="Remediation" FontWeight="SemiBold" Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding ImeHealthRemediationSummary}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource OverviewBorderStyle}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="Installierte Apps / Deployments mit GUID" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                                    <DataGrid ItemsSource="{Binding ManagedAppInsights}" Style="{StaticResource AppLogDataGridStyle}" MinHeight="280" CanUserAddRows="False" CanUserDeleteRows="False">
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn Header="" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="45" />
                                            <DataGridTextColumn Header="App Name" Binding="{Binding AppName}" Width="260" />
                                            <DataGridTextColumn Header="GUID" Binding="{Binding AppGuid}" Width="250" />
                                            <DataGridTextColumn Header="Package ID" Binding="{Binding PackageId}" Width="170" />
                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="130" />
                                            <DataGridTextColumn Header="Applicability" Binding="{Binding Applicability}" Width="180" />
                                            <DataGridTextColumn Header="Error Code" Binding="{Binding ErrorCode}" Width="130" />
                                            <DataGridTextColumn Header="Desired State" Binding="{Binding DesiredState}" Width="130" />
                                            <DataGridTextColumn Header="TargetingMethod" Binding="{Binding TargetingMethod}" Width="130" />
                                            <DataGridTextColumn Header="Install Context" Binding="{Binding InstallContext}" Width="130" />
                                            <DataGridTextColumn Header="TargetType" Binding="{Binding TargetType}" Width="120" />
                                            <DataGridTextColumn Header="Product Version" Binding="{Binding ProductVersion}" Width="140" />
                                            <DataGridTextColumn Header="RebootStatus" Binding="{Binding RebootStatus}" Width="140" />
                                            <DataGridTextColumn Header="RebootReason" Binding="{Binding RebootReason}" Width="180" />
                                            <DataGridTextColumn Header="UserID" Binding="{Binding UserId}" Width="220" />
                                            <DataGridTextColumn Header="ComputerID" Binding="{Binding ComputerId}" Width="220" />
                                            <DataGridTextColumn Header="ComplianceStateMessage" Binding="{Binding ComplianceStateMessage}" Width="360" />
                                            <DataGridTextColumn Header="EnforcementStateMessage" Binding="{Binding EnforcementStateMessage}" Width="360" />
                                            <DataGridTextColumn Header="Fehler / Hinweis" Binding="{Binding ErrorHint}" Width="180" />
                                            <DataGridTextColumn Header="Quelle" Binding="{Binding SourceLog}" Width="170" />
                                            <DataGridTextColumn Header="Letzter Hinweis" Binding="{Binding LastSeen}" Width="150" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Company Portal Logs">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource OverviewBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Company Portal Übersicht" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding CompanyPortalOverviewText}" TextWrapping="Wrap" Margin="0,0,0,6" />
                            <TextBlock Text="{Binding CompanyPortalOverviewSignalText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource OverviewBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Suche" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBox Height="30" Text="{Binding CompanyPortalSearchTerm, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Filter" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <ComboBox Height="30" ItemsSource="{Binding AvailableFilters}" SelectedItem="{Binding CompanyPortalSelectedFilter}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TabControl Grid.Row="2">
                        <TabItem Header="Company Portal" Visibility="{Binding IsCompanyPortalVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource OverviewBorderStyle}">
                                    <TextBlock Text="{Binding CompanyPortalSummaryText}" TextWrapping="Wrap" />
                                </Border>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding CompanyPortalEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                        <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="900" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="220" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Enrollment" Visibility="{Binding IsEnrollmentVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource OverviewBorderStyle}">
                                    <TextBlock Text="{Binding EnrollmentSummaryText}" TextWrapping="Wrap" />
                                </Border>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding EnrollmentEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                        <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="900" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="220" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="MDM Diagnoseartefakte" Visibility="{Binding IsMdmDiagnosticsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource OverviewBorderStyle}">
                                    <TextBlock Text="{Binding MdmDiagnosticsSummaryText}" TextWrapping="Wrap" />
                                </Border>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding MdmDiagnosticsEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                        <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="900" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="220" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Event-Log-Kanäle" Visibility="{Binding IsEventLogChannelsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource OverviewBorderStyle}">
                                    <TextBlock Text="{Binding EventLogChannelsSummaryText}" TextWrapping="Wrap" />
                                </Border>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding EventLogChannelEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                        <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="900" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="220" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Install-Agent Events" Visibility="{Binding IsInstallAgentEventsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource OverviewBorderStyle}">
                                    <TextBlock Text="{Binding InstallAgentEventsSummaryText}" TextWrapping="Wrap" />
                                </Border>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding InstallAgentEventsEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                        <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="1000" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="220" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>

            <TabItem Header="Intune Logs">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource OverviewBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Intune Logs Übersicht" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding IntuneLogsOverviewText}" TextWrapping="Wrap" Margin="0,0,0,6" />
                            <TextBlock Text="{Binding IntuneLogsOverviewSignalText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource OverviewBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Suche" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBox Height="30" Text="{Binding IntuneLogsSearchTerm, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Filter" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <ComboBox Height="30" ItemsSource="{Binding AvailableFilters}" SelectedItem="{Binding IntuneLogsSelectedFilter}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TabControl Grid.Row="2" Margin="8,0,0,0">
                        <TabItem Header="AgentExecutor.log" Visibility="{Binding IsAgentExecutorVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGrid ItemsSource="{Binding AgentExecutorEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                    <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="900" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="170" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="AppActionProcessor.log" Visibility="{Binding IsAppActionProcessorVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGrid ItemsSource="{Binding AppActionProcessorEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                    <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="900" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="170" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="AppWorkload.log" Visibility="{Binding IsAppWorkloadVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGrid ItemsSource="{Binding AppWorkloadEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                    <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="900" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="170" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="ClientCertCheck.log" Visibility="{Binding IsClientCertCheckVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGrid ItemsSource="{Binding ClientCertCheckEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                    <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="900" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="170" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="ClientHealth.log" Visibility="{Binding IsClientHealthVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGrid ItemsSource="{Binding ClientHealthEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                    <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="900" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="170" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="IntuneManagementExtension.log" Visibility="{Binding IsIntuneManagementExtensionVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGrid ItemsSource="{Binding IntuneManagementExtensionEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                    <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="900" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="170" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="NotificationInfraLogs.log" Visibility="{Binding IsNotificationInfraLogsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGrid ItemsSource="{Binding NotificationInfraLogsEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                    <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="900" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="170" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Sensor.log" Visibility="{Binding IsSensorVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGrid ItemsSource="{Binding SensorEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                    <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="900" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="170" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Win32AppInventory.log" Visibility="{Binding IsWin321AppInventoryVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGrid ItemsSource="{Binding Win321AppInventoryEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                    <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="900" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="170" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Intune Support Suite Remote Audit Log" Visibility="{Binding IsRemoteAuditVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGrid ItemsSource="{Binding RemoteAuditEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                    <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="900" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="190" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Intune Support Suite Fallback Log" Visibility="{Binding IsFallbackVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGrid ItemsSource="{Binding FallbackEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                    <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="900" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="190" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>

            <TabItem Header="Lokale App Logs">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource OverviewBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Lokale App Log Übersicht" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding LocalAppLogsOverviewText}" TextWrapping="Wrap" Margin="0,0,0,6" />
                            <TextBlock Text="{Binding LocalAppLogsOverviewSignalText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource OverviewBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Suche" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBox Height="30" Text="{Binding LocalLogsSearchTerm, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Filter" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <ComboBox Height="30" ItemsSource="{Binding AvailableFilters}" SelectedItem="{Binding LocalLogsSelectedFilter}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TabControl Grid.Row="2" Margin="8,0,0,0">
                        <TabItem Header="Intune Support Suite" Style="{StaticResource LocalLogTabItemStyle}" Visibility="{Binding IsLocalAppLogVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGrid ItemsSource="{Binding LocalAppLogEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                    <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="900" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="190" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Trust Log" Style="{StaticResource LocalLogTabItemStyle}" Visibility="{Binding IsTrustLogVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGrid ItemsSource="{Binding TrustLogEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                    <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="900" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="190" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Log Verlauf" Style="{StaticResource LocalLogTabItemStyle}" Visibility="{Binding IsAppDataLogsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGrid ItemsSource="{Binding AppDataLogsEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                    <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="900" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="190" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>

            <TabItem Header="Remediation">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource OverviewBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Remediation Übersicht" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding RemediationSummaryText}" TextWrapping="Wrap" Margin="0,0,0,6" />
                            <TextBlock Text="{Binding ImeHealthRemediationSignal}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource OverviewBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Suche" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBox Height="30" Text="{Binding RemediationSearchTerm, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Filter" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <ComboBox Height="30" ItemsSource="{Binding AvailableFilters}" SelectedItem="{Binding RemediationSelectedFilter}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TabControl Grid.Row="2">
                        <TabItem Header="HealthScripts.log" Visibility="{Binding IsHealthScriptsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGrid ItemsSource="{Binding HealthScriptsEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                    <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="900" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="170" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="DeviceHealthMonitoring.log" Visibility="{Binding IsDeviceHealthMonitoringVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGrid ItemsSource="{Binding DeviceHealthMonitoringEntriesView}" Style="{StaticResource AppLogDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Zeit" Binding="{Binding DisplayTimestamp}" Width="170" />
                                    <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="100" />
                                        <DataGridTextColumn Header="Log Zeile" Binding="{Binding Message}" Width="900" />
                                        <DataGridTextColumn Header="Datei" Binding="{Binding SourceFile}" Width="170" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>


            <TabItem Header="Registry Einstellungen">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource OverviewBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Intune Relevante Registry Einstellungen" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding IntuneRelevantRegistrySettingsSummaryText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1"
                              Margin="0,12,0,0"
                              ItemsSource="{Binding IntuneRelevantRegistrySettings}"
                              Style="{StaticResource AppLogDataGridStyle}"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kategorie" Binding="{Binding Category}" Width="220" />
                            <DataGridTextColumn Header="Setting" Binding="{Binding SettingName}" Width="220" />
                            <DataGridTextColumn Header="Wert" Binding="{Binding Value}" Width="180" />
                            <DataGridTextColumn Header="Empfehlung" Binding="{Binding Recommendation}" Width="340" />
                            <DataGridTextColumn Header="Interpretation" Binding="{Binding Interpretation}" Width="260" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="140" />
                            <DataGridTextColumn Header="Registry-Pfad" Binding="{Binding RegistryPath}" Width="*" MinWidth="520" />
                            <DataGridTextColumn Header="Quelle" Binding="{Binding SourceLog}" Width="170" />
                            <DataGridTextColumn Header="Letzter Hinweis" Binding="{Binding LastSeen}" Width="150" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3" Background="White" CornerRadius="6" Margin="0,12,0,0" BorderBrush="#D7E0E8" BorderThickness="1">
            <Grid>
                <ProgressBar Minimum="0"
                             Maximum="100"
                             Value="{Binding ProgressValue}"
                             Height="32"
                             VerticalAlignment="Stretch"
                             Background="White"
                             Foreground="#9AD66D"
                             BorderThickness="0" />
                <Grid Background="Transparent" Margin="10,4,10,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding ConfigVersionText}" VerticalAlignment="Center" Background="Transparent" />
                    <TextBlock Grid.Column="1" Text=" | " VerticalAlignment="Center" Background="Transparent" />
                    <TextBlock Grid.Column="2" Text="{Binding StatusMessage}" VerticalAlignment="Center" TextWrapping="Wrap" Background="Transparent" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
