<Application x:Class="DapIntuneSupportSuite.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DapIntuneSupportSuite">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <SolidColorBrush x:Key="CiBlueBrush" Color="#005EA8" />
        <SolidColorBrush x:Key="CiBlueDarkBrush" Color="#0B3D66" />
        <SolidColorBrush x:Key="CiAccentBrush" Color="#009FE3" />
        <SolidColorBrush x:Key="CiWarnBrush" Color="#F7D154" />
        <SolidColorBrush x:Key="CiErrorBrush" Color="#E05A5A" />
        <SolidColorBrush x:Key="CiNeutralBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F4F7FA" />
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="{StaticResource CiBlueBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="EnableRowVirtualization" Value="True" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="#EEF4F8" />
            <Setter Property="EnableColumnVirtualization" Value="True" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Visible" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        </Style>
    </Application.Resources>
</Application>
